# docker-compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=project1    # プロジェクト名（全て小文字）
CONTAINER_NAME=Docker_Linux

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=gentoo_docker.sh

VOLUME=./build

WS=build

MIRROR=https://ftp.iij.ad.jp/pub/linux/gentoo
STAGE3_ARCH="amd64"

CPU_CORE=4

TIME_ZONE=Asia/Tokyo
LOCALE="ja_JP.UTF-8 UTF-8"
LANG="ja_JP.UTF-8"

ROOT_PASSWORD="password"
